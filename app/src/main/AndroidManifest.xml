<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <application
        android:name=".KyPostApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KyPost" >

        <activity
            android:name=".ThemesActivity"
            android:exported="false" />

        <activity
            android:name=".KeywordSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".EmailDetailActivity"
            android:exported="false" />

        <activity
            android:name=".ComposeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".InboxActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".contacts.ContactsListActivity"
            android:exported="false" />

        <activity
            android:name=".contacts.ContactDetailActivity"
            android:exported="false" />

        <activity
            android:name=".contacts.ContactEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".pgp.PgpKeyActivity"
            android:exported="false" />

        <activity
            android:name=".push.PushPairingActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Thin, stateless forwarder for kypost://native-pair — see PushPairingLinkActivity
             for why the exported surface is split from PushPairingActivity itself. -->
        <activity
            android:name=".push.PushPairingLinkActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="native-pair"
                    android:scheme="kypost" />
            </intent-filter>
        </activity>

        <service
            android:name=".push.KyPostFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <service
            android:name=".push.KyPostUnifiedPushService"
            android:exported="false">
            <intent-filter>
                <action android:name="org.unifiedpush.android.connector.PUSH_EVENT" />
            </intent-filter>
        </service>

        <receiver
            android:name=".push.MfaResponseReceiver"
            android:exported="false" />

        <!-- taskAffinity="" keeps this in its own task, separate from MainActivity's. Without
             it, tapping the notification after the app process has died resolves to the app's
             existing (dead) task by affinity, which recreates MainActivity as the task root
             instead of reliably launching this activity on top — landing the user on the inbox
             instead of the approve/deny screen. -->
        <activity
            android:name=".push.MfaApprovalActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:taskAffinity="" />

        <service
            android:name=".contacts.device.KyPostContactAuthenticatorService"
            android:exported="false">
            <intent-filter>
                <action android:name="android.accounts.AccountAuthenticator" />
            </intent-filter>
            <meta-data
                android:name="android.accounts.AccountAuthenticator"
                android:resource="@xml/contact_authenticator" />
        </service>

        <provider
            android:name=".security.EphemeralAttachmentProvider"
            android:authorities="${applicationId}.ephemeralattachments"
            android:exported="false"
            android:grantUriPermissions="true" />

        <activity
            android:name=".security.UnlockActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true" />

        <activity
            android:name=".security.SecuritySettingsActivity"
            android:exported="false" />

    </application>

</manifest>